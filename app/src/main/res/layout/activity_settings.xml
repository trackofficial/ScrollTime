<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
android:background="@color/black">

    <!-- Заголовок -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Settings"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:fontFamily="@font/geist_semibold"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
android:background="@color/black"
        android:layout_marginBottom="16dp"
        android:elevation="2dp">

        <TextView
            android:id="@+id/tvSettingsNotification"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📢 Уведомления: активно"
            android:textSize="14sp"
            android:paddingVertical="3dp" />

        <TextView
            android:id="@+id/tvSettingsOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🖼️ Поверх других окон: активно"
            android:textSize="14sp"
            android:paddingVertical="3dp" />

        <TextView
            android:id="@+id/tvSettingsAccessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="♿ Сл. Доступности: активно"
            android:textSize="14sp"
            android:paddingVertical="3dp" />

    </LinearLayout>

    <Button
        android:visibility="gone"
        android:id="@+id/btnResetAll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🗑️ Сбросить все настройки"
        android:backgroundTint="#FF5722"
        android:layout_marginBottom="16dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/settingsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp" />

    </ScrollView>

</LinearLayout>