<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
android:background="@color/black">

    <View
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/app_icon"
        />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="P.S. приложение создано для ограничения просмотра коротких видео"
        android:textSize="12sp"
        android:textColor="#666666"
        android:fontFamily="@font/geist_regular"
        android:layout_marginBottom="10dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Status"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:fontFamily="@font/geist_semibold"
        android:layout_marginBottom="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
android:background="@color/black"

        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tvNotificationStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Уведомления: активно"
            android:textSize="14sp"
            android:paddingVertical="2dp" />

        <TextView
            android:id="@+id/tvOverlayStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Поверх других окон: активно"
            android:textSize="14sp"
            android:paddingVertical="2dp" />

        <TextView
            android:id="@+id/tvAccessibilityStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Сл. Доступности: активно"
            android:textSize="14sp"
            android:paddingVertical="2dp" />

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Info"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="@font/geist_semibold"
        android:textColor="@color/white"
        android:layout_marginBottom="6dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="• Не собирает и не передает вашу личную информацию (работает локально)\n• Работает только с YouTube Shorts, Reels, TikTok\n• Лимит сбрасывается каждый день"
        android:textSize="12sp"
        android:textColor="@color/white"
android:background="@color/black"
        android:fontFamily="@font/geist_regular"
        android:layout_marginBottom="24dp"
        android:lineSpacingExtra="6dp" />

    <FrameLayout
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:background="@drawable/button_form">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Настроить сл. Доступности"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/geist_regular" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/btnEnableAccessibility"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent" />

    </FrameLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:background="@drawable/button_form">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Открыть настройки лимитов"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/geist_regular" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/btnOpenSettings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent" />

    </FrameLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:background="@drawable/button_form">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="14dp">

            <TextView
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Проверить активность разрешений"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/geist_regular" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/btnCheckPermissions"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent" />

    </FrameLayout>

</LinearLayout>